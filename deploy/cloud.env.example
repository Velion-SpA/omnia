# Omnia Cloud server environment template — `omnia cloud serve`.
#
# Every OMNIA_* variable below also accepts its legacy ENGRAM_* name as a
# fallback (see internal/envx), so existing setups keep working. Use the
# OMNIA_* names for anything new.
#
# Install this file at /etc/omnia/cloud.env (referenced by
# deploy/omnia-cloud.service's EnvironmentFile=) and lock it down:
#   sudo install -o omnia -g omnia -m 0600 cloud.env.example /etc/omnia/cloud.env
#   sudo editor /etc/omnia/cloud.env   # fill in the real secrets below
#
# See deploy/HOMELAB.md for the full from-scratch bring-up.

# ── Required: database ──────────────────────────────────────────────────────
# Postgres DSN. The schema (accounts, memberships, sync tables, ...)
# auto-migrates on every boot — no manual migration step needed.
# The built-in default (postgres://engram:engram_dev@localhost:5433/engram_cloud)
# is a LOCAL DEV CREDENTIAL — never use it outside a throwaway smoke test.
OMNIA_DATABASE_URL=postgres://omnia:CHANGE_ME_STRONG_PASSWORD@localhost:5432/omnia_cloud?sslmode=disable

# ── Required: auth ───────────────────────────────────────────────────────────
# Signs account tokens (JWT-style, 24h TTL). Generate a real secret — the
# server REFUSES to boot in authenticated mode with the built-in dev default.
#   openssl rand -base64 48
OMNIA_JWT_SECRET=CHANGE_ME_32_BYTES_MINIMUM_NON_DEFAULT_SECRET

# Legacy shared bearer token for sync push/pull (kept working alongside the
# per-account token auth added later; see OBL-01 for managed/revocable tokens).
# Required unless OMNIA_CLOUD_INSECURE_NO_AUTH=1 (dev only, see below).
#   openssl rand -hex 32
OMNIA_CLOUD_TOKEN=CHANGE_ME_SHARED_BEARER_TOKEN

# Comma-separated project allowlist. REQUIRED even in insecure/no-auth mode —
# there is no wildcard-open default. Use "*" only for a fully trusted
# dev/internal deploy; for the two-notebook homelab test, list the real
# project names (e.g. "homelab,velion").
OMNIA_CLOUD_ALLOWED_PROJECTS=CHANGE_ME_project_a,project_b

# Optional admin-only dashboard token (separate from per-account login).
# Leave unset if you only use account login for the dashboard.
# OMNIA_CLOUD_ADMIN=CHANGE_ME_OPTIONAL_ADMIN_TOKEN

# ── Optional: managed per-user tokens (OBL-01, hashed + pepper + revocable) ──
# Off by default (the legacy OMNIA_CLOUD_TOKEN shared secret above keeps
# working unchanged). Set OMNIA_CLOUD_MANAGED_TOKENS=1 to enable issuing
# revocable per-user tokens; boot REFUSES to start with managed tokens
# enabled but an empty/default pepper.
#   openssl rand -base64 48
# OMNIA_CLOUD_MANAGED_TOKENS=1
# OMNIA_CLOUD_TOKEN_PEPPER=CHANGE_ME_32_BYTES_MINIMUM_NON_DEFAULT_PEPPER

# ── Network ──────────────────────────────────────────────────────────────────
# Bind host. Keep 127.0.0.1 (the code default) unless this process is behind
# a reverse proxy on the SAME host — see deploy/Caddyfile.example. Do NOT set
# this to 0.0.0.0 without a reverse proxy in front of it: the binary has no
# built-in TLS, so 0.0.0.0 without a proxy means auth tokens and passwords
# travel in clear HTTP on the LAN.
OMNIA_CLOUD_HOST=0.0.0.0

# Port omnia cloud serve listens on (default: 8080 if unset).
OMNIA_PORT=8080

# Max accepted push payload size in bytes (default: 8388608 = 8MiB).
# OMNIA_CLOUD_MAX_PUSH_BYTES=8388608

# ── Dev-only escape hatch — do NOT use on the homelab server ────────────────
# Disables ALL cloud API authentication. Cannot be combined with
# OMNIA_CLOUD_TOKEN or OMNIA_CLOUD_ADMIN. Only ever appropriate for an
# ephemeral local smoke test (see scripts/e2e-cloud-isolation.sh).
# OMNIA_CLOUD_INSECURE_NO_AUTH=1
