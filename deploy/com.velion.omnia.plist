<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.velion.omnia</string>
    <key>ProgramArguments</key>
    <array>
        <!-- Build the binary first: go build -o /usr/local/bin/omnia ./cmd/omnia -->
        <string>/usr/local/bin/omnia</string>
        <string>sync</string>
    </array>
    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>2</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>
    <key>StandardOutPath</key>
    <string>/tmp/omnia.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/omnia-error.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
        <!-- Replace the placeholder values below with your actual tokens before loading -->
        <key>GITHUB_TOKEN</key>
        <string>REPLACE_WITH_YOUR_GITHUB_TOKEN</string>
        <key>DISCORD_BOT_TOKEN</key>
        <string>REPLACE_WITH_YOUR_DISCORD_BOT_TOKEN</string>
    </dict>
</dict>
</plist>
