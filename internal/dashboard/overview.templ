package dashboard

import (
	"fmt"

	"github.com/velion/omnia/internal/ui"
)

// overviewPage renders the home "Command Center" overview.
templ overviewPage(data OverviewData) {
	@layout("overview", ui.T(ctx, "overview.pageTitle")) {
		<!-- Bento grid -->
		<div style="display: grid; grid-template-columns: repeat(12, 1fr); grid-template-rows: auto auto 1fr; gap: 12px; min-height: calc(100vh - 120px);">

			<!-- TILE: Total Memories (cols 1-4) -->
			<div class="panel accented" style="grid-column: 1 / 5;">
				<div class="tile-label">{ ui.T(ctx, "overview.totalMemories") }</div>
				<div class="tile-value" id="cnt-total">{ fmt.Sprintf("%d", data.TotalMemories) }</div>
			</div>

			<!-- TILE: Projects (cols 5-8) -->
			<div class="panel accented" style="grid-column: 5 / 9;">
				<div class="tile-label">{ ui.T(ctx, "overview.projects") }</div>
				<div class="tile-value" id="cnt-projects">{ fmt.Sprintf("%d", data.TotalProjects) }</div>
			</div>

			<!-- TILE: Last Sync (cols 9-12) -->
			<div class="panel accented" style="grid-column: 9 / 13;">
				<div class="tile-label">{ ui.T(ctx, "overview.lastSync") }</div>
				if data.LastSync != "" {
					<div class="tile-value" style="font-size: 32px;">{ data.LastSync }</div>
					<div class="tile-delta live">● { data.LastSyncSource } · { ui.T(ctx, "overview.autoMode") }</div>
				} else {
					<div class="tile-value" style="font-size: 22px; color: var(--text-2);">—</div>
					<div class="tile-delta neutral">{ ui.T(ctx, "overview.noSyncYet") }</div>
				}
			</div>

			<!-- LEFT: Projects list (cols 1-4, rows 2-4) -->
			<div class="panel bracketed" style="grid-column: 1 / 5; grid-row: 2 / 4; display: flex; flex-direction: column;">
				<div class="panel-header">
					<div>
						<div class="panel-eyebrow">{ ui.T(ctx, "overview.knowledgeBases") }</div>
						<div class="panel-title">{ ui.T(ctx, "overview.projects") }</div>
					</div>
					<div class="panel-badge">{ ui.T(ctx, "overview.sortedByCount") }</div>
				</div>
				<div style="flex: 1; overflow-y: auto;">
					if len(data.Projects) == 0 {
						<p style="color: var(--text-2); font-size: 10px;">{ ui.T(ctx, "overview.noProjectsPrefix") }<code>omnia sync</code>{ ui.T(ctx, "overview.noProjectsSuffix") }</p>
					} else {
						for i, p := range data.Projects {
							<div class="proj-row" style="display: grid; grid-template-columns: 18px 1fr auto 44px; align-items: center; gap: 10px; padding: 9px 0; border-bottom: 1px solid var(--border-2);">
								<span class="proj-rank">{ fmt.Sprintf("%02d", i+1) }</span>
								<span class="proj-name-cell">
									<a href={ templ.SafeURL(projectDetailURL(p.Name)) } class="proj-name" style="text-decoration: none;">{ p.Name }</a>
									if data.ShowClouds {
										@cloudPills(p.Clouds)
									}
								</span>
								if p.LatestUpdateAt != "" {
									if isFresh(p.LatestUpdateAt) {
										<span class="freshness fresh"><span class="freshness-pip"></span>{ ui.T(ctx, "overview.freshnessFresh") }</span>
									} else {
										<span class="freshness stale"><span class="freshness-pip"></span>{ ui.T(ctx, "overview.freshnessReview") }</span>
									}
								} else {
									<span></span>
								}
								<a href={ templ.SafeURL("/browse?project=" + p.Name) } class="proj-count" style="text-decoration: none;" title="Browse all">{ fmt.Sprintf("%d", p.Total) }</a>
							</div>
						}
					}
				</div>
			</div>

			<!-- CENTER TOP: Memory Types (cols 5-8, row 2) -->
			<div class="panel" style="grid-column: 5 / 9; grid-row: 2;">
				<div class="panel-header">
					<div>
						<div class="panel-eyebrow">{ ui.T(ctx, "overview.breakdown") }</div>
						<div class="panel-title">{ ui.T(ctx, "overview.memoryTypes") }</div>
					</div>
				</div>
				if len(data.ByType) == 0 {
					<p style="color: var(--text-2); font-size: 10px;">{ ui.T(ctx, "overview.noTypeData") }</p>
				} else {
					<!-- Bar chart — rendered via inline script below. ByType is capped to 8 by buildOverviewData. -->
					<div id="type-bars">
						for _, tc := range data.ByType {
							<div class="cat-row">
								<div class="cat-meta">
									<span class="cat-name">{ tc.Name }</span>
									<span class="cat-count">{ fmt.Sprintf("%d", tc.Count) }</span>
								</div>
								<div class="cat-track">
									<div class="cat-fill" data-color={ typeColor(tc.Name) } data-pct={ typePct(tc.Count, data.ByType) }></div>
								</div>
							</div>
						}
					</div>
				}
			</div>

			<!-- CENTER BOTTOM: Live Feed (cols 5-8, row 3) -->
			<div class="panel" style="grid-column: 5 / 9; grid-row: 3;">
				<div class="panel-header">
					<div>
						<div class="panel-eyebrow">{ ui.T(ctx, "overview.recentIngest") }</div>
						<div class="panel-title">{ ui.T(ctx, "overview.liveFeed") }</div>
					</div>
					<div class="live-badge">
						<span class="live-dot"></span>{ ui.T(ctx, "overview.live") }
					</div>
				</div>
				if len(data.LiveFeed) == 0 {
					<p style="color: var(--text-2); font-size: 10px;">{ ui.T(ctx, "overview.noRecentActivity") }</p>
				} else {
					for _, item := range data.LiveFeed {
						<div class="feed-item">
							if item.Type != "" {
								<div class="feed-tag" style={ "color:" + typeColor(item.Type) + "; background: " + typeColorBg(item.Type) + ";" }>
									<span class="feed-tag-pip"></span>{ item.Type }
								</div>
							}
							<div class="feed-title">
								<a href={ templ.SafeURL(fmt.Sprintf("/detail/%d", item.ID)) } style="color: var(--text); text-decoration: none;">
									{ item.Title }
								</a>
							</div>
							<div class="feed-footer">
								<span>{ item.Age }</span>
								if item.Project != "" {
									<span>·</span>
									<span class="feed-proj">{ item.Project }</span>
								}
							</div>
						</div>
					}
				}
			</div>

			<!-- RIGHT: Sources (cols 9-12, rows 2-4) -->
			<div class="panel" style="grid-column: 9 / 13; grid-row: 2 / 4;">
				<div style="margin-bottom: 18px;">
					<div class="panel-eyebrow">{ ui.T(ctx, "overview.connected") }</div>
					<div class="panel-title">{ ui.T(ctx, "overview.sources") }</div>
				</div>
				for _, s := range data.Sources {
					<div class="source-row">
						<div class="source-icon">
							@sourceIcon(s.IconKey)
						</div>
						<div class="source-info">
							<div class="source-name">{ s.Name }</div>
							<div class="source-sub">{ s.Sub }</div>
						</div>
						<div class="source-count">{ fmt.Sprintf("%d", s.Count) }</div>
					</div>
				}
			</div>

		</div><!-- /bento grid -->

		<script>
			// Animate type bars after DOM is ready.
			(function() {
				requestAnimationFrame(function() {
					setTimeout(function() {
						document.querySelectorAll('.cat-fill').forEach(function(f) {
							f.style.background = f.dataset.color || '#22d3ee';
							f.style.width = (f.dataset.pct || '0') + '%';
						});
					}, 200);
				});
			})();

			// Counter animation for metric tiles.
			function countUp(el, target, duration) {
				if (!el || isNaN(target)) return;
				var ease = function(t) { return 1 - Math.pow(1 - t, 3); };
				var start = performance.now();
				function frame(now) {
					var p = Math.min((now - start) / duration, 1);
					el.textContent = Math.round(ease(p) * target).toLocaleString();
					if (p < 1) requestAnimationFrame(frame);
				}
				requestAnimationFrame(frame);
			}
			setTimeout(function() {
				var t = document.getElementById('cnt-total');
				var p = document.getElementById('cnt-projects');
				if (t) countUp(t, parseInt(t.textContent.replace(/,/g,'')), 1400);
				if (p) countUp(p, parseInt(p.textContent.replace(/,/g,'')), 800);
			}, 150);
		</script>
	}
}

// cloudPills renders one pill per cloud a project is loaded on, colored by
// health (green healthy / amber pending|running / red degraded|blocked via the
// badge-warn/badge-bad modifiers, which win the color properties over
// .cloud-pill's defaults because they're declared later in the stylesheet) —
// or a single muted "local-only" pill when the project is on no cloud. A
// degraded/blocked target renders red instead of disappearing (OBL-12).
templ cloudPills(clouds []CloudPlacement) {
	<span class="cloud-pills">
		if len(clouds) == 0 {
			<span class="cloud-pill local">local-only</span>
		} else {
			for _, c := range clouds {
				<span
					class={ "cloud-pill", templ.KV("badge-warn", c.Status == CloudPillPending), templ.KV("badge-bad", c.Status == CloudPillDegraded) }
					title={ cloudPillTitle(c) }
				>{ c.Name }</span>
			}
		}
	</span>
}

// cloudPillTitle returns a hover tooltip explaining an unhealthy pill's reason
// code, so the operator doesn't have to leave the overview to find out why a
// target is amber/red. Empty for a healthy pill (nothing to explain).
func cloudPillTitle(c CloudPlacement) string {
	if c.Status == CloudPillHealthy {
		return ""
	}
	if c.ReasonCode != "" {
		return string(c.Status) + ": " + c.ReasonCode
	}
	return string(c.Status)
}

// sourceIcon renders the SVG icon for a given source key.
templ sourceIcon(key string) {
	switch key {
	case "github":
		<svg viewBox="0 0 24 24" width="18" height="18" fill="#8a9ab5">
			<path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0012 2z"></path>
		</svg>
	case "discord":
		<svg viewBox="0 0 24 24" width="18" height="18" fill="#818cf8">
			<path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03z"></path>
		</svg>
	default:
		<!-- Claude Code / curated -->
		<svg viewBox="0 0 24 24" width="18" height="18" fill="none">
			<circle cx="12" cy="12" r="4" fill="#22d3ee" opacity="0.9"></circle>
			<circle cx="12" cy="12" r="8" stroke="#22d3ee" stroke-width="0.75" opacity="0.35"></circle>
			<line x1="12" y1="2" x2="12" y2="6" stroke="#22d3ee" stroke-width="1.2" stroke-linecap="round"></line>
			<line x1="22" y1="12" x2="18" y2="12" stroke="#22d3ee" stroke-width="1.2" stroke-linecap="round"></line>
			<line x1="12" y1="22" x2="12" y2="18" stroke="#22d3ee" stroke-width="1.2" stroke-linecap="round"></line>
			<line x1="2" y1="12" x2="6" y2="12" stroke="#22d3ee" stroke-width="1.2" stroke-linecap="round"></line>
		</svg>
	}
}

// typePct returns the bar fill percentage for a type count relative to the max.
func typePct(count int, all []TypeCount) string {
	if len(all) == 0 || all[0].Count == 0 {
		return "0"
	}
	pct := (count * 100) / all[0].Count
	return fmt.Sprintf("%d", pct)
}

// typeColorBg returns a translucent background for a type color chip.
func typeColorBg(t string) string {
	switch t {
	case "architecture":
		return "rgba(34,211,238,0.08)"
	case "decision":
		return "rgba(56,189,248,0.08)"
	case "bugfix":
		return "rgba(96,165,250,0.08)"
	case "discovery":
		return "rgba(129,140,248,0.08)"
	case "config":
		return "rgba(167,139,250,0.08)"
	case "pattern":
		return "rgba(192,132,252,0.08)"
	default:
		return "rgba(138,154,181,0.08)"
	}
}
